# VulnForge AI - configuracao via variaveis de ambiente
# Copie para .env e ajuste. Tudo e opcional: sem chave, o analyzer usa modo rule-based offline.

# --- LLM (OpenRouter por padrao) ---
VULNFORGE_LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
VULNFORGE_LLM_MODEL=anthropic/claude-sonnet-4
VULNFORGE_LLM_BASE_URL=https://openrouter.ai/api/v1

# Reprodutibilidade (metodologia academica): determinismo via temperature 0 + seed.
VULNFORGE_LLM_TEMPERATURE=0.0
VULNFORGE_LLM_SEED=1337

# --- Modelo local reprodutivel (provider=local), endpoint OpenAI-compativel (Ollama/vLLM) ---
# VULNFORGE_LLM_PROVIDER=local
# VULNFORGE_LLM_BASE_URL=http://localhost:11434/v1
# VULNFORGE_LLM_MODEL=qwen2.5-coder:32b

# --- Armazenamento ---
VULNFORGE_DB_PATH=data/vulnforge.db
VULNFORGE_DATA_DIR=data

# --- Logging ---
VULNFORGE_LOG_LEVEL=INFO

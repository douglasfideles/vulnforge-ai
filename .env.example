# VulnForge AI - example environment configuration.
# Copy this file to .env and fill in the values you need.

# LLM provider: openrouter | local | offline
VULNFORGE_LLM_PROVIDER=offline

# Model identifier for OpenRouter / local OpenAI-compatible endpoint
VULNFORGE_LLM_MODEL=anthropic/claude-sonnet-4

# Base URL for the chat completions endpoint
VULNFORGE_LLM_BASE_URL=https://openrouter.ai/api/v1

# OpenRouter API key (no VULNFORGE_ prefix)
OPENROUTER_API_KEY=

# Deterministic LLM parameters
VULNFORGE_LLM_TEMPERATURE=0.0
VULNFORGE_LLM_SEED=1337

# Paths and logging
VULNFORGE_DB_PATH=data/vulnforge.db
VULNFORGE_DATA_DIR=data
VULNFORGE_LOG_LEVEL=INFO
